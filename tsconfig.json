{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@forge/platform": ["packages/platform/src/index.ts"],
      "@forge/platform/*": ["packages/platform/src/*"],
      "@forge/sales": ["packages/modules/sales/src/index.ts"],
      "@forge/sales/*": ["packages/modules/sales/src/*"],
      "@forge/inventory": ["packages/modules/inventory/src/index.ts"],
      "@forge/inventory/*": ["packages/modules/inventory/src/*"]
    }
  },
  "include": ["packages/**/*.ts"]
}
